# Copy to `env` and edit. Both scripts source `env` on start.
# Never commit an `env` with real bearer tokens.

# ----- shared -----
# Where to write CSVs. Created if missing.
OUT_DIR="${HOME}/krot-soak-out"

# ----- server side (VDS-A) -----
# krot-server admin API endpoint (must be reachable from the machine
# that runs `server.sh`; usually the same host).
ADMIN_URL="http://127.0.0.1:7580"

# Admin bearer token minted via the enrollment flow — required to
# scrape /metrics.
ADMIN_TOKEN="paste-your-session-bearer-here"

# How often (seconds) to sample /metrics and server RSS.
SCRAPE_INTERVAL=30

# ----- client side (VDS-B) -----
# Newline-separated list of tunnel URLs to hammer. Each line one URL.
# Example content of urls.txt:
#   https://alice.example.com/
#   https://bob.example.com/
URLS_FILE="${HOME}/krot-soak-out/urls.txt"

# Requests per second PER URL. E.g. 5 with 20 URLs = 100 RPS total.
RATE_PER_URL=5

# Max in-flight requests. Backpressure knob — if the target is slow,
# this caps how many curls are outstanding.
CONCURRENCY=64

# How long to run the load generator. Format: "5m", "6h", "12h", etc.
DURATION="6h"

# curl timeout per request in seconds.
CURL_TIMEOUT=10
